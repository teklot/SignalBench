## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Ww]in32/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Oo]ut/
log/
intermediate/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio Code design time settings
.vscode/

# CoreCLR dumps
core.[0-9]*

# Azurite local emulator files
__blobstorage__
__queuestorage__
__azurite_db*__.json

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# JetBrains Resharper temp files
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Ninja build file reports
.ninja_log
.ninja_deps

# DotCover is a Code Coverage Tool
*.dotCover

# AxoCover is a Code Coverage Tool
.axoCover/*
!.axoCover/settings.json

# Coverlet is a Code Coverage Tool
coverage/*.json
coverage/*.xml
coverage/*.html

# Visual Studio code coverage results
*.coverage
*.coveragexml

# NCrunch
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# MightyMoose
*.mm.*
AutoTest.Net/

# Web workbench (sass)
.sass-cache/

# Installshield output folder
[Ee]xpress/

# DocProject is a documentation generator for Visual Studio
DocProject/buildhelp/
DocProject/Help/*.mcweb

# COHESION
#  Add description of why Cohesion needs this
Cohesion/

# ClickOnce directory:
publish/

# Publish Web Output
*.[Pp]ublish.xml
*.azurePubxml
# Note: Comment the next line if you want to checkin your web deploy settings,
# but be aware that they can contain sensitive information
*.pubxml
*.pubxml.user

# OTAR-specific files
*.sbx
*.db
*.log

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project dependencies
#!**/[Pp]ackages/
# NuGet Symbol Source Packages
*.snupkg

# BOWER Support
bower_components/

# Windows temp files
Thumbs.db
ehthumbs.db
Desktop.ini

# JFM (Just-In-Time debugger)
*.jfm

# TypeScript v1.1
*.pfx
*.publishsettings

# Avalonia
.avalonia/
Artifacts/
