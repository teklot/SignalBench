<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="SignalBench.App"
             xmlns:local="using:SignalBench"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <!-- Global Window Icon -->
        <Style Selector="Window">
            <Setter Property="Icon" Value="/Assets/signalbench_logo.ico" />
        </Style>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <mi:MaterialIconStyles />

        <!-- Shared Sidebar/Panel Section Header -->
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,15,0,5"/>
        </Style>

        <!-- Shared Input Field Label -->
        <Style Selector="TextBlock.InputLabel">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>

        <!-- Sidebar Header (within Expander or Border) -->
        <Style Selector="TextBlock.PanelHeader">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Word-like Toolbar Button Style -->
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Styles>
</Application>