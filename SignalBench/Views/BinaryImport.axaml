<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="SignalBench.Views.BinaryImport"
        x:DataType="vm:BinaryImportViewModel"
        Title="Import Binary"
        WindowStartupLocation="CenterOwner"
        Width="900" Height="650">

    <Grid RowDefinitions="*, Auto">
        <!-- Main Content -->
        <Grid Grid.Row="0" RowDefinitions="Auto, *">
            <!-- Top Section: Schema Settings -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20">
                <StackPanel Spacing="15">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DATA FILE"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding TelemetryPath}"
                                     IsReadOnly="True"
                                     Watermark="Select binary telemetry file..."/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseTelemetryCommand}"
                                    Margin="8,0,0,0"
                                    ToolTip.Tip="Open Binary Telemetry">
                                <mi:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </StackPanel>

                    <Grid ColumnDefinitions="2.5*, *" ColumnSpacing="30">
                        <!-- Schema Selection -->
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="SCHEMA"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding SchemaFilePath}"
                                         IsReadOnly="True"
                                         Watermark="Select YAML schema file..."/>
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseSchemaCommand}"
                                        Margin="5,0,0,0"
                                        ToolTip.Tip="Open Schema File">
                                    <mi:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                        
                        <!-- Timestamp Selection -->
                        <StackPanel Grid.Column="1" Spacing="8">
                            <TextBlock Text="TIMESTAMP COLUMN"
                                       FontWeight="Bold"
                                       FontSize="11"
                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            <ComboBox ItemsSource="{Binding AvailableColumns}"
                                      SelectedItem="{Binding TimestampField}"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Select field..."/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Bottom Section: Data Preview -->
            <Border Grid.Row="1" Padding="20">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" 
                                Orientation="Horizontal" 
                                Spacing="5" 
                                Margin="0,0,0,10">
                        <TextBlock Text="PREVIEW"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding SelectedSchema.Name, StringFormat='({0})'}"
                                   IsVisible="{Binding SelectedSchema, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   FontWeight="Bold"
                                   FontSize="11"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1">
                        <DataGrid Name="PreviewGrid"
                                  ItemsSource="{Binding PreviewRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  HeadersVisibility="All"
                                  Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                  x:CompileBindings="False">
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="20,15"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="100"
                        HorizontalContentAlignment="Center"/>
                <Button Content="Import"
                        Command="{Binding ImportCommand}"
                        IsEnabled="{Binding IsImportEnabled}"
                        Width="100"
                        HorizontalContentAlignment="Center"
                        Classes="accent"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
