<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="SignalBench.Views.CsvImport"
        x:DataType="vm:CsvImportViewModel"
        Title="Import CSV"
        WindowStartupLocation="CenterOwner"
        Width="700" Height="550">

    <Grid RowDefinitions="*, Auto">
        <!-- Content Area -->
        <Grid Grid.Row="0" RowDefinitions="Auto, *">
            <!-- Settings Section -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="SETTINGS"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />

                    <Grid ColumnDefinitions="Auto, 150, Auto, 200">
                        <TextBlock Text="Delimiter:"
                                   VerticalAlignment="Center"
                                   Margin="0,0,12,0"
                                   FontSize="13" />
                        <ComboBox Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  SelectedItem="{Binding Delimiter}">
                            <x:String>,</x:String>
                            <x:String>;</x:String>
                            <x:String>|</x:String>
                            <x:String>Tab</x:String>
                        </ComboBox>

                        <TextBlock Grid.Column="2"
                                   Text="Timestamp Column:"
                                   VerticalAlignment="Center"
                                   Margin="30,0,12,0"
                                   FontSize="13" />
                        <ComboBox Grid.Column="3"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding AvailableColumns}"
                                  SelectedItem="{Binding TimestampColumn}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Preview Section -->
            <Border Grid.Row="1" Padding="20">
                <Grid RowDefinitions="Auto, *">
                    <TextBlock Grid.Row="0"
                               Text="PREVIEW"
                               FontWeight="Bold"
                               FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,10" />
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                            BorderThickness="1">
                        <DataGrid Name="PreviewGrid"
                                  ItemsSource="{Binding PreviewRecords}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  HeadersVisibility="All"
                                  Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
                                  x:CompileBindings="False">
                        </DataGrid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer Actions -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="20,15"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12">
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Width="100"
                        HorizontalContentAlignment="Center" />
                <Button Content="Import"
                        Command="{Binding ImportCommand}"
                        Width="100"
                        HorizontalContentAlignment="Center"
                        Classes="accent" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
