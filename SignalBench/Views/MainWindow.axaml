<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SignalBench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/signalbench_logo.ico"
        Title="{Binding AppTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Telemetry..." Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileChartOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Recent Telemetry" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate>
                            <MenuItem Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenRecentFileCommand}"
                                      CommandParameter="{Binding Path}">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Index, StringFormat='\{0\}.'}" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        <TextBlock Text="{Binding Path}"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Open _Session..." Command="{Binding OpenSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileSearchOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save Session..." Command="{Binding SaveSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export CSV..." Command="{Binding ExportCsvCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileExportOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            
            <MenuItem Header="_View">
                <MenuItem Header="Signals Panel" 
                          Command="{Binding ToggleSignalsPaneCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding IsSignalsPaneOpen}" IsHitTestVisible="False"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_Open Schema..." Command="{Binding LoadSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileDocumentOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_New Schema..." Command="{Binding CreateSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FilePlusOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Edit Current Schema..." Command="{Binding EditSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileEditOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="SettingsOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding OpenAboutCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="InformationOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid ColumnDefinitions="Auto, *">
                <StackPanel Orientation="Horizontal" Spacing="0" Margin="5,2">
                    <Button Classes="toolbar" Command="{Binding ToggleSignalsPaneCommand}" ToolTip.Tip="Toggle Signals Panel" VerticalAlignment="Center">
                        <mi:MaterialIcon Kind="Menu" Width="20" Height="20"/>
                    </Button>
                    
                    <Separator Width="1" Margin="8,10"/>

                    <!-- Session Group -->
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="5,0">
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                            <Button Classes="toolbar" Command="{Binding OpenSessionCommand}" ToolTip.Tip="Open Session">
                                <mi:MaterialIcon Kind="FileSearchOutline" Width="20" Height="20"/>
                            </Button>
                            <Button Classes="toolbar" Command="{Binding SaveSessionCommand}" ToolTip.Tip="Save Session">
                                <mi:MaterialIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="SESSION" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <Separator Width="1" Margin="8,10"/>

                    <!-- Data Group -->
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="5,0">
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                            <Button Classes="toolbar" Command="{Binding OpenFileCommand}" ToolTip.Tip="Open Telemetry File">
                                <mi:MaterialIcon Kind="FileChartOutline" Width="20" Height="20"/>
                            </Button>
                            <Button Classes="toolbar" Command="{Binding ExportCsvCommand}" ToolTip.Tip="Export CSV">
                                <mi:MaterialIcon Kind="FileExportOutline" Width="20" Height="20"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="DATA" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <Separator Width="1" Margin="8,10"/>

                    <!-- Schema Group -->
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="5,0">
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Center">
                            <Button Classes="toolbar" Command="{Binding LoadSchemaCommand}" ToolTip.Tip="Open Schema File">
                                <mi:MaterialIcon Kind="FileDocumentOutline" Width="20" Height="20"/>
                            </Button>
                            <Button Classes="toolbar" Command="{Binding CreateSchemaCommand}" ToolTip.Tip="Create New Schema">
                                <mi:MaterialIcon Kind="FilePlusOutline" Width="20" Height="20"/>
                            </Button>
                            <Button Classes="toolbar" Command="{Binding EditSchemaCommand}" ToolTip.Tip="Edit Current Schema">
                                <mi:MaterialIcon Kind="FileEditOutline" Width="20" Height="20"/>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="SCHEMA" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <Separator Width="1" Margin="8,10"/>

                    <!-- Settings -->
                    <StackPanel Orientation="Vertical" Spacing="2" Margin="5,0">
                        <Button Classes="toolbar" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings" HorizontalAlignment="Center">
                            <mi:MaterialIcon Kind="SettingsOutline" Width="20" Height="20"/>
                        </Button>
                        <TextBlock Text="APP" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1" Padding="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <mi:MaterialIcon Kind="InformationOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <SplitView DisplayMode="Inline"
                   IsPaneOpen="{Binding IsSignalsPaneOpen}"
                   OpenPaneLength="280">
            <SplitView.Pane>
                <!-- Left Panel (Sidebar) -->
                <Grid RowDefinitions="Auto, *" Margin="15,15,0,15">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,10,10">
                        <TextBlock Grid.Column="0" Text="SIGNALS" Classes="header" VerticalAlignment="Center" Margin="0"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSignalsPaneCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                ToolTip.Tip="Close Panel">
                            <mi:MaterialIcon Kind="Close" Width="14" Height="14"/>
                        </Button>
                    </Grid>
                    
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding AvailableSignals}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,10,0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"
                                          FontSize="13"
                                          Margin="0"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <!-- Plot Area -->
                <Border Padding="10">
                    <scott:AvaPlot Name="MainPlot"/>
                </Border>
            </SplitView.Content>
        </SplitView>
    </DockPanel>
</Window>
