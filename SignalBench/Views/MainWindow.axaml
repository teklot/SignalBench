<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:converters="using:SignalBench.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:views="using:SignalBench.Views"
        xmlns:uc="using:SignalBench.UserControls"
        xmlns:sdk="using:SignalBench.SDK.Interfaces"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="850"
        x:Class="SignalBench.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppTitle}"

        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <Thickness x:Key="TabItemPipeThickness">0</Thickness>
        <SolidColorBrush x:Key="TabItemHeaderSelectedPipeFill" Color="Transparent" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Padding" Value="12,6"/>
        </Style>

        <!-- Browser-like Tab Styles -->
        <Style Selector="TabStrip">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style Selector="TabStripItem">
            <Setter Property="Padding" Value="12,6,8,6"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="CornerRadius" Value="8,8,0,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>
        <Style Selector="TabStripItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
        <Style Selector="TabStripItem:selected">
            <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemAccentColor}"/>
            <!-- Shift selected tab down 1px to overlap the bottom border of the header area -->
            <Setter Property="Margin" Value="0,0,2,-1"/>
            <Setter Property="Padding" Value="12,7,8,7"/>
        </Style>
        <Style Selector="TabStripItem:selected TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <!-- Remove the active tab indicator (underline) -->
        <Style Selector="TabStripItem /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Height" Value="0"/>
        </Style>
        <Style Selector="TabStripItem:selected /template/ Border#PART_SelectedPipe">
            <Setter Property="IsVisible" Value="False"/>
            <Setter Property="Height" Value="0"/>
        </Style>
        
        <!-- Tab Close Button Styling -->
        <Style Selector="TabStripItem Button.tab-close">
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Foreground" Value="{Binding $parent[TabStripItem].Foreground}"/>
        </Style>
        <Style Selector="TabStripItem:pointerover Button.tab-close">
            <Setter Property="Opacity" Value="1"/>
        </Style>
        <Style Selector="TabStripItem Button.tab-close:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
        </Style>
        <Style Selector="TabStripItem Button.tab-close mi|MaterialIcon">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
        </Style>
    </Window.Styles>

    <DockPanel Background="{DynamicResource SystemRegionBrush}">
        <!-- 1. Top Menu Bar -->
        <uc:MainMenu DockPanel.Dock="Top" />

        <!-- 2. Ribbon Toolbar -->
        <uc:RibbonToolbar DockPanel.Dock="Top" />

        <!-- 3. Tab Area -->
        <uc:TabHeader DockPanel.Dock="Top" />

        <!-- 4. Status Bar -->
        <uc:StatusBar DockPanel.Dock="Bottom" />

        <!-- 5. Main Content Area (Workspaces) -->
        <ContentControl Content="{Binding SelectedTab}" />
    </DockPanel>
</Window>
