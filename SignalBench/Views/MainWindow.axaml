<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:converters="using:SignalBench.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:views="using:SignalBench.Views"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SignalBench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/signalbench_logo.ico"
        Title="{Binding AppTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Word-like Toolbar Button Style -->
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#edebe9"/>
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#e1dfdd"/>
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Sidebar Header Style -->
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#605e5c"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style Selector="Menu">
            <Setter Property="Background" Value="White"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </Window.Styles>

    <DockPanel Background="White">
        <!-- 1. Top Menu Bar -->
        <Menu DockPanel.Dock="Top" BorderBrush="#e1dfdd" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Telemetry..." Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="TableLarge" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Recent Telemetry" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentFileViewModel">
                            <Button Content="{Binding DisplayName}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenRecentFileCommand}"
                                    CommandParameter="{Binding Path}"
                                    Padding="0"/>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Open _Session..." Command="{Binding OpenSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FolderOpenOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save Session..." Command="{Binding SaveSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close _All" Command="{Binding CloseAllCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="WindowClose" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export CSV..." Command="{Binding ExportCsvCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileExportOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            
            <MenuItem Header="_View">
                <MenuItem Header="Signals Panel" 
                          Command="{Binding ToggleSignalsPaneCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Check" IsVisible="{Binding IsSignalsPaneOpen}" Width="18" Height="18" Foreground="#2b579a"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Toolbar" 
                          Command="{Binding ToggleToolbarCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Check" IsVisible="{Binding IsToolbarVisible}" Width="18" Height="18" Foreground="#2b579a"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="_New Schema..." Command="{Binding CreateSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FilePlusOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Edit Current Schema..." Command="{Binding EditSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileDocumentEditOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Create Derived Signal..." Command="{Binding CreateDerivedSignalCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FunctionVariant" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="SettingsOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding OpenAboutCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="InformationOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- 2. Ribbon Toolbar -->
        <Border DockPanel.Dock="Top" Background="#f3f2f1" BorderBrush="#e1dfdd" BorderThickness="0,0,0,1" IsVisible="{Binding IsToolbarVisible}">
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <!-- SESSION GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding OpenSessionCommand}" ToolTip.Tip="Open Session">
                            <mi:MaterialIcon Kind="FolderOpenOutline" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding SaveSessionCommand}" ToolTip.Tip="Save Session">
                            <mi:MaterialIcon Kind="ContentSaveOutline" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding CloseAllCommand}" ToolTip.Tip="Close All / Reset Workspace">
                            <mi:MaterialIcon Kind="WindowClose" Width="22" Height="22" Foreground="#d83b01"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="SESSION" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#605e5c" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="#e1dfdd" VerticalAlignment="Stretch"/>
                
                <!-- DATA GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding OpenFileCommand}" ToolTip.Tip="Open Telemetry File">
                            <mi:MaterialIcon Kind="TableLarge" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding ExportCsvCommand}" ToolTip.Tip="Export CSV">
                            <mi:MaterialIcon Kind="FileExportOutline" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="DATA" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#605e5c" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="#e1dfdd" VerticalAlignment="Stretch"/>
                
                <!-- SCHEMA GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding CreateSchemaCommand}" ToolTip.Tip="Create New Schema">
                            <mi:MaterialIcon Kind="FilePlusOutline" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding EditSchemaCommand}" ToolTip.Tip="Edit Current Schema">
                            <mi:MaterialIcon Kind="FileDocumentEditOutline" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding CreateDerivedSignalCommand}" ToolTip.Tip="Create Derived Signal">
                            <mi:MaterialIcon Kind="FunctionVariant" Width="22" Height="22" Foreground="#2b579a"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="SCHEMA" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#605e5c" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="#e1dfdd" VerticalAlignment="Stretch"/>
                
                <!-- APP GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6" VerticalAlignment="Center">
                    <Button Classes="toolbar" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="SettingsOutline" Width="22" Height="22" Foreground="#605e5c"/>
                    </Button>
                    <TextBlock Text="APP" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="#605e5c" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 3. Status Bar (Docked Bottom) -->
        <Border DockPanel.Dock="Bottom" 
                Background="#f3f2f1" 
                BorderBrush="#e1dfdd" 
                BorderThickness="0,1,0,0" 
                Height="28" 
                Padding="10,0">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <mi:MaterialIcon Kind="InformationOutline" Width="14" Height="14" Foreground="#2b579a"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#323130" VerticalAlignment="Center"/>
                </StackPanel>
                
                <!-- Progress bar shown during loading -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding IsLoading}">
                    <ProgressBar Value="{Binding LoadProgress}" Width="100" Height="10"/>
                    <TextBlock Text="{Binding LoadElapsed}" FontSize="11" Foreground="#605e5c" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. Main Content Area -->
        <Grid ColumnDefinitions="Auto, *">
            <!-- Vertical Tab Strip -->
            <Border Grid.Column="0" Width="24" Background="#f3f2f1" BorderBrush="#e1dfdd" BorderThickness="0,0,1,0" IsVisible="{Binding !IsSignalsPaneOpen}">
                <Button Command="{Binding ToggleSignalsPaneCommand}" 
                        Background="Transparent" BorderThickness="0" Padding="0" 
                        VerticalAlignment="Top" Margin="0,20,0,0"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Width="24" Height="100">
                    <LayoutTransformControl>
                        <LayoutTransformControl.LayoutTransform>
                            <RotateTransform Angle="-90"/>
                        </LayoutTransformControl.LayoutTransform>
                        <TextBlock Text="SIGNALS" FontSize="11" FontWeight="Bold" Foreground="#2b579a"/>
                    </LayoutTransformControl>
                </Button>
            </Border>

            <!-- Workspace Grid -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <!-- Two-way bind to handle resizing while allowing logic-based collapse -->
                    <ColumnDefinition Width="{Binding SignalsPaneColumnWidth, Mode=TwoWay}" MinWidth="0" MaxWidth="600"/>
                    <ColumnDefinition Width="Auto"/> <!-- Splitter -->
                    <ColumnDefinition Width="*"/>    <!-- Plot -->
                </Grid.ColumnDefinitions>

                <!-- Open Signals Sidebar -->
                <Border Grid.Column="0" 
                        HorizontalAlignment="Stretch"
                        Background="White" BorderBrush="#e1dfdd" BorderThickness="0,0,1,0" 
                        IsVisible="{Binding IsSignalsPaneOpen}">
                    <Grid RowDefinitions="Auto, *">
                        <Border Grid.Row="0" Background="#f3f2f1" Height="32" Padding="10,0">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" Text="SIGNALS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#2b579a"/>
                                <Button Grid.Column="1" Command="{Binding ToggleSignalsPaneCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Collapse">
                                    <mi:MaterialIcon Kind="ChevronLeft" Width="14" Height="14" Foreground="#2b579a"/>
                                </Button>
                            </Grid>
                        </Border>
                        <views:SignalsView Grid.Row="1" />
                    </Grid>
                </Border>

                <!-- GridSplitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="#e1dfdd" IsVisible="{Binding IsSignalsPaneOpen}"/>

                <!-- Plot Area -->
                <Border Grid.Column="2" Padding="15">
                    <Grid RowDefinitions="*, Auto">
                        <views:PlotView Grid.Row="0" />
                        
                        <!-- Replay Controls - Bottom of Plot -->
                        <Border Grid.Row="1" 
                                Background="#f3f2f1" 
                                CornerRadius="4" 
                                Padding="8,3" 
                                Margin="0,5,0,0"
                                IsVisible="{Binding HasData}">
                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">
                                <!-- Fast Backward (1%) -->
                                <Button Grid.Column="0" Command="{Binding FastBackwardCommand}" ToolTip.Tip="Fast Backward (1%)" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                    <mi:MaterialIcon Kind="SkipBackward" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Step Back -->
                                <Button Grid.Column="1" Command="{Binding StepBackwardCommand}" ToolTip.Tip="Step Back" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                    <mi:MaterialIcon Kind="ChevronLeft" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Play/Pause -->
                                <Button Grid.Column="2" Command="{Binding PlayPauseCommand}" ToolTip.Tip="Play/Pause" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                    <mi:MaterialIcon Kind="{Binding IsPlaying, Converter={x:Static converters:BoolToPlayIconConverter.Instance}}" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Step Forward -->
                                <Button Grid.Column="3" Command="{Binding StepForwardCommand}" ToolTip.Tip="Step Forward" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                    <mi:MaterialIcon Kind="ChevronRight" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Fast Forward (1%) -->
                                <Button Grid.Column="4" Command="{Binding FastForwardCommand}" ToolTip.Tip="Fast Forward (1%)" Background="Transparent" BorderThickness="0" Width="32" Height="32">
                                    <mi:MaterialIcon Kind="SkipForward" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Timestamp Display -->
                                <Border Grid.Column="5" 
                                        Background="#edebe9" 
                                        CornerRadius="2"
                                        Padding="8,2"
                                        Margin="10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FormattedPlaybackTime}" 
                                               FontFamily="Consolas, Courier New, monospace" 
                                               FontSize="11.5" 
                                               LineHeight="14"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="#2b579a"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <!-- Restart -->
                                <Button Grid.Column="6" Command="{Binding RestartCommand}" ToolTip.Tip="Restart" Background="Transparent" BorderThickness="0" Width="32" Height="32" Margin="0,0,15,0">
                                    <mi:MaterialIcon Kind="Replay" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Timeline Slider -->
                                <Slider Grid.Column="7" Value="{Binding PlaybackProgress}" Minimum="0" Maximum="100" VerticalAlignment="Center" IsEnabled="{Binding !IsPlaying}"/>
                                
                                <!-- Speed -->
                                <ComboBox Grid.Column="8" ItemsSource="{Binding PlaybackSpeeds}" SelectedItem="{Binding PlaybackSpeed, Converter={x:Static converters:DoubleToStringConverter.Instance}}" Width="90" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
