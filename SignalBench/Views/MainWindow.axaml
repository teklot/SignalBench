<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SignalBench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/signalbench_logo.ico"
        Title="SignalBench v0.1">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Telemetry..." Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <ic:SymbolIcon Symbol="FolderOpen" FontSize="18"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Open _Session..." Command="{Binding OpenSessionCommand}">
                    <MenuItem.Icon>
                        <ic:SymbolIcon Symbol="FolderSearch" FontSize="18"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save Session..." Command="{Binding SaveSessionCommand}">
                    <MenuItem.Icon>
                        <ic:SymbolIcon Symbol="Save" FontSize="18"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export CSV..." Command="{Binding ExportCsvCommand}">
                    <MenuItem.Icon>
                        <ic:SymbolIcon Symbol="ArrowExportUp" FontSize="18"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            
            <MenuItem Header="_View">
                <MenuItem Header="Signals Panel" 
                          Command="{Binding ToggleSignalsPaneCommand}">
                    <MenuItem.Icon>
                        <CheckBox IsChecked="{Binding IsSignalsPaneOpen}" IsHitTestVisible="False"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Schema Editor..." Command="{Binding CreateSchemaCommand}">
                    <MenuItem.Icon>
                        <ic:SymbolIcon Symbol="Edit" FontSize="18"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto, *">
                <StackPanel Orientation="Horizontal">
                    <Button Classes="toolbar" Command="{Binding ToggleSignalsPaneCommand}" ToolTip.Tip="Toggle Signals Panel">
                        <ic:SymbolIcon Symbol="Navigation" FontSize="18"/>
                    </Button>
                    <Separator Width="1" Margin="4,8"/>
                    <Button Classes="toolbar" Command="{Binding OpenFileCommand}" ToolTip.Tip="Open Telemetry File">
                        <ic:SymbolIcon Symbol="FolderOpen" FontSize="18"/>
                    </Button>
                    <Separator Width="1" Margin="4,8"/>
                    <Button Classes="toolbar" Command="{Binding OpenSessionCommand}" ToolTip.Tip="Open Session">
                        <ic:SymbolIcon Symbol="FolderSearch" FontSize="18"/>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding SaveSessionCommand}" ToolTip.Tip="Save Session">
                        <ic:SymbolIcon Symbol="Save" FontSize="18"/>
                    </Button>
                    <Separator Width="1" Margin="4,8"/>
                    <Button Classes="toolbar" Command="{Binding ExportCsvCommand}" ToolTip.Tip="Export CSV">
                        <ic:SymbolIcon Symbol="ArrowExportUp" FontSize="18"/>
                    </Button>
                    <Separator Width="1" Margin="4,8"/>
                    <Button Classes="toolbar" Command="{Binding CreateSchemaCommand}" ToolTip.Tip="Schema Editor">
                        <ic:SymbolIcon Symbol="Edit" FontSize="18"/>
                    </Button>
                </StackPanel>

                <Border Grid.Column="1" Padding="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <ic:SymbolIcon Symbol="Info" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <SplitView DisplayMode="Inline"
                   IsPaneOpen="{Binding IsSignalsPaneOpen}"
                   OpenPaneLength="280">
            <SplitView.Pane>
                <!-- Left Panel (Sidebar) -->
                <Grid RowDefinitions="Auto, *" Margin="15,15,0,15">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,10,10">
                        <TextBlock Grid.Column="0" Text="SIGNALS" Classes="header" VerticalAlignment="Center" Margin="0"/>
                        <Button Grid.Column="1"
                                Command="{Binding ToggleSignalsPaneCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="4"
                                ToolTip.Tip="Close Panel">
                            <ic:SymbolIcon Symbol="Dismiss" FontSize="14"/>
                        </Button>
                    </Grid>
                    
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding AvailableSignals}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,0,10,0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding Name}"
                                          IsChecked="{Binding IsSelected}"
                                          FontSize="13"
                                          Margin="0"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </SplitView.Pane>

            <SplitView.Content>
                <!-- Plot Area -->
                <Border Padding="10">
                    <scott:AvaPlot Name="MainPlot"/>
                </Border>
            </SplitView.Content>
        </SplitView>
    </DockPanel>
</Window>
