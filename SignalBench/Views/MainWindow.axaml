<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:ic="using:FluentIcons.Avalonia.Fluent"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SignalBench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/signalbench_logo.ico"
        Title="SignalBench v0.1">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Top Toolbar -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto, *">
                <StackPanel Orientation="Horizontal">
                    <Button Classes="toolbar" Command="{Binding OpenFileCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="FolderOpen" FontSize="18"/>
                            <TextBlock Text="Open Telemetry" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding LoadSchemaCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Document" FontSize="18"/>
                            <TextBlock Text="Load Schema" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Margin="8,8"/>
                    <Button Classes="toolbar" Command="{Binding SaveSessionCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="Save" FontSize="18"/>
                            <TextBlock Text="Save Session" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding ExportCsvCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ic:SymbolIcon Symbol="ArrowExportUp" FontSize="18"/>
                            <TextBlock Text="Export CSV" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <Border Grid.Column="1" Padding="15,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                        <ic:SymbolIcon Symbol="Info" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusText}" 
                                   VerticalAlignment="Center" 
                                   FontSize="12"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="280, *">
            <!-- Left Panel (Sidebar) -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto, *" Margin="15">
                    <!-- Schema Selection -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,25">
                        <TextBlock Text="SCHEMA" Classes="header"/>
                        <ComboBox HorizontalAlignment="Stretch" 
                                  ItemsSource="{Binding Schemas}" 
                                  SelectedItem="{Binding SelectedSchema}"
                                  PlaceholderText="Select Schema...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <!-- Signal List -->
                    <Grid Grid.Row="1" RowDefinitions="Auto, *">
                        <TextBlock Grid.Row="0" Text="SIGNALS" Classes="header"/>
                        <Border Grid.Row="1" 
                                CornerRadius="3" 
                                ClipToBounds="True"
                                Background="{DynamicResource SystemControlBackgroundListLowBrush}"
                                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                                BorderThickness="1">
                            <ListBox ItemsSource="{Binding AvailableSignals}"
                                     Background="Transparent"
                                     BorderThickness="0">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Name}" 
                                                  IsChecked="{Binding IsSelected}"
                                                  FontSize="13"
                                                  Margin="0"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Plot Area -->
            <Border Grid.Column="1" Padding="10">
                <scott:AvaPlot Name="MainPlot"/>
            </Border>
        </Grid>
    </Grid>
</Window>
