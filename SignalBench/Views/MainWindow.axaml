<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:converters="using:SignalBench.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scott="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        xmlns:mi="using:Material.Icons.Avalonia"
        xmlns:views="using:SignalBench.Views"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
        x:Class="SignalBench.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppTitle}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <!-- Word-like Toolbar Button Style -->
        <Style Selector="Button.toolbar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.toolbar:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
        </Style>
        <Style Selector="Button.toolbar:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>
        <Style Selector="Button.toolbar:disabled">
            <Setter Property="Opacity" Value="0.4"/>
        </Style>
        <Style Selector="Button.toolbar:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- Sidebar Header Style -->
        <Style Selector="TextBlock.header">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style Selector="Menu">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="MenuItem">
            <Setter Property="Padding" Value="12,6"/>
        </Style>
    </Window.Styles>

    <DockPanel Background="{DynamicResource SystemRegionBrush}">
        <!-- 1. Top Menu Bar -->
        <Menu DockPanel.Dock="Top" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Telemetry..." Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="TableLarge" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Recent Telemetry" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentFileViewModel">
                            <Button Content="{Binding DisplayName}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).OpenRecentFileCommand}"
                                    CommandParameter="{Binding Path}"
                                    Padding="0"/>
                        </DataTemplate>
                    </MenuItem.ItemTemplate>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Open _Session..." Command="{Binding OpenSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FolderOpenOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Save Session..." Command="{Binding SaveSessionCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Close _All" Command="{Binding CloseAllCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="WindowClose" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Export CSV..." Command="{Binding ExportCsvCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileExportOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            
            <MenuItem Header="_View">
                <MenuItem Header="Signals Panel" 
                          Command="{Binding ToggleSignalsPaneCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Check" IsVisible="{Binding IsSignalsPaneOpen}" Width="18" Height="18" Foreground="{DynamicResource SystemAccentColor}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Toolbar" 
                          Command="{Binding ToggleToolbarCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Check" IsVisible="{Binding IsToolbarVisible}" Width="18" Height="18" Foreground="{DynamicResource SystemAccentColor}"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>


            <MenuItem Header="_Tools">
                <MenuItem Header="_Open Schema..." Command="{Binding OpenSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FolderOpenOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_New Schema..." Command="{Binding CreateSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FilePlusOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Edit Current Schema..." Command="{Binding EditSchemaCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FileDocumentEditOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Serial Stream Settings..." Command="{Binding OpenSerialSettingsCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="SerialPort" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="_Network Stream Settings..." Command="{Binding OpenNetworkSettingsCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Lan" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="Record Live Stream"
                          Command="{Binding ToggleRecordingCommand}"
                          IsEnabled="{Binding IsStreaming}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="{Binding IsRecording, Converter={x:Static converters:BoolToRecordIconConverter.Instance}}" Width="20" Height="20" Foreground="{Binding IsRecording, Converter={x:Static converters:BoolToColorConverter.Instance}, ConverterParameter='Recording'}"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Create Derived Signal..." Command="{Binding CreateDerivedSignalCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="FunctionVariant" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="SettingsOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding OpenAboutCommand}">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="InformationOutline" Width="20" Height="20"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- 2. Ribbon Toolbar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1" IsVisible="{Binding IsToolbarVisible}">
            <StackPanel Orientation="Horizontal" Margin="5,0">
                <!-- SESSION GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding OpenSessionCommand}" ToolTip.Tip="Open Session">
                            <mi:MaterialIcon Kind="FolderOpenOutline" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding SaveSessionCommand}" ToolTip.Tip="Save Session">
                            <mi:MaterialIcon Kind="ContentSaveOutline" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding CloseAllCommand}" ToolTip.Tip="Close All / Reset Workspace">
                            <mi:MaterialIcon Kind="WindowClose" Width="22" Height="22" Foreground="#d83b01"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="SESSION" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Stretch"/>
                
                <!-- DATA FILE GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding OpenFileCommand}" ToolTip.Tip="Open Telemetry File">
                            <mi:MaterialIcon Kind="TableLarge" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding ExportCsvCommand}" ToolTip.Tip="Export CSV">
                            <mi:MaterialIcon Kind="FileExportOutline" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="DATA FILE" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Stretch"/>

                <!-- STREAM GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Button Classes="toolbar" Command="{Binding ToggleStreamingCommand}" ToolTip.Tip="Serial Stream">
                            <Grid Width="24" Height="24" ClipToBounds="False">
                                <mi:MaterialIcon Kind="SerialPort" Width="24" Height="24" Foreground="{DynamicResource SystemAccentColor}"/>
                                <!-- Bordered Badge (Pro Look) -->
                                <Border Background="{DynamicResource SystemRegionBrush}" 
                                        CornerRadius="5"
                                        Padding="1"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top" 
                                        Margin="0,-3,-6,0"
                                        IsVisible="{Binding IsSerialStreaming}">
                                    <Ellipse Width="8" Height="8">
                                        <Ellipse.Fill>
                                            <MultiBinding Converter="{x:Static converters:StreamingStateToIndicatorColorConverter.Instance}">
                                                <Binding Path="IsSerialStreaming"/>
                                                <Binding Path="IsSerialPaused"/>
                                            </MultiBinding>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Border>
                            </Grid>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding ToggleUdpStreamingCommand}" ToolTip.Tip="Network Stream">
                            <Grid Width="24" Height="24" ClipToBounds="False">
                                <mi:MaterialIcon Kind="Lan" Width="24" Height="24" Foreground="{DynamicResource SystemAccentColor}"/>
                                <!-- Bordered Badge (Pro Look) -->
                                <Border Background="{DynamicResource SystemRegionBrush}" 
                                        CornerRadius="5"
                                        Padding="1"
                                        HorizontalAlignment="Right" 
                                        VerticalAlignment="Top" 
                                        Margin="0,-3,-3,0"
                                        IsVisible="{Binding IsNetworkStreaming}">
                                    <Ellipse Width="8" Height="8">
                                        <Ellipse.Fill>
                                            <MultiBinding Converter="{x:Static converters:StreamingStateToIndicatorColorConverter.Instance}">
                                                <Binding Path="IsNetworkStreaming"/>
                                                <Binding Path="IsNetworkPaused"/>
                                            </MultiBinding>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                </Border>
                            </Grid>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding ToggleRecordingCommand}" ToolTip.Tip="{Binding IsRecording, Converter={x:Static converters:BoolToRecordIconConverter.Instance}, ConverterParameter='Tooltip'}" IsEnabled="{Binding IsStreaming}">
                            <mi:MaterialIcon Kind="{Binding IsRecording, Converter={x:Static converters:BoolToRecordIconConverter.Instance}}" Width="24" Height="24" Foreground="{Binding IsRecording, Converter={x:Static converters:BoolToColorConverter.Instance}, ConverterParameter='Recording'}"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="STREAM" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Stretch"/>
                
                <!-- SCHEMA GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                        <Button Classes="toolbar" Command="{Binding CreateSchemaCommand}" ToolTip.Tip="Create New Schema">
                            <mi:MaterialIcon Kind="FilePlusOutline" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding EditSchemaCommand}" ToolTip.Tip="Edit Current Schema">
                            <mi:MaterialIcon Kind="FileDocumentEditOutline" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                        <Button Classes="toolbar" Command="{Binding CreateDerivedSignalCommand}" ToolTip.Tip="Create Derived Signal">
                            <mi:MaterialIcon Kind="FunctionVariant" Width="22" Height="22" Foreground="{DynamicResource SystemAccentColor}"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="SCHEMA" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" VerticalAlignment="Stretch"/>
                
                <!-- APP GROUP -->
                <StackPanel Orientation="Vertical" Margin="8,6" VerticalAlignment="Center">
                    <Button Classes="toolbar" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Settings" HorizontalAlignment="Center">
                        <mi:MaterialIcon Kind="SettingsOutline" Width="22" Height="22" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </Button>
                    <TextBlock Text="APP" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 3. Status Bar (Docked Bottom) -->
        <Border DockPanel.Dock="Bottom" 
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" 
                BorderThickness="0,1,0,0" 
                Height="28" 
                Padding="10,0">
            <Grid ColumnDefinitions="*, Auto, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <mi:MaterialIcon Kind="InformationOutline" Width="14" Height="14" Foreground="{DynamicResource SystemAccentColor}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    
                    <!-- Dynamic Connection Info -->
                    <Border Width="1" Height="14" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="8,0" IsVisible="{Binding SelectedPlot.ConnectionInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding SelectedPlot.ConnectionInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <mi:MaterialIcon Kind="{Binding SelectedPlot.ConnectionIcon}" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        <TextBlock Text="{Binding SelectedPlot.ConnectionInfo}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>                </StackPanel>
                
                <!-- Progress bar shown during loading -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" IsVisible="{Binding IsLoading}">
                    <ProgressBar Value="{Binding LoadProgress}" Width="100" Height="10"/>
                    <TextBlock Text="{Binding LoadElapsed}" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 4. Main Content Area -->
        <Grid ColumnDefinitions="Auto, *">
            <!-- Vertical Tab Strip -->
            <Border Grid.Column="0" Width="24" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" IsVisible="{Binding !IsSignalsPaneOpen}">
                <Button Command="{Binding ToggleSignalsPaneCommand}" 
                        Background="Transparent" BorderThickness="0" Padding="0" 
                        VerticalAlignment="Top" Margin="0,20,0,0"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Width="24" Height="100">
                    <LayoutTransformControl>
                        <LayoutTransformControl.LayoutTransform>
                            <RotateTransform Angle="-90"/>
                        </LayoutTransformControl.LayoutTransform>
                        <TextBlock Text="SIGNALS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}"/>
                    </LayoutTransformControl>
                </Button>
            </Border>

            <!-- Workspace Grid -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <!-- Two-way bind to handle resizing while allowing logic-based collapse -->
                    <ColumnDefinition Width="{Binding SignalsPaneColumnWidth, Mode=TwoWay}" MinWidth="0" MaxWidth="600"/>
                    <ColumnDefinition Width="Auto"/> <!-- Splitter -->
                    <ColumnDefinition Width="*"/>    <!-- Plot -->
                </Grid.ColumnDefinitions>

                <!-- Open Signals Sidebar -->
                <Border Grid.Column="0" 
                        HorizontalAlignment="Stretch"
                        Background="{DynamicResource SystemRegionBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" 
                        IsVisible="{Binding IsSignalsPaneOpen}">
                    <Grid RowDefinitions="Auto, *">
                        <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Height="32" Padding="10,0">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" Text="SIGNALS" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource SystemAccentColor}"/>
                                <Button Grid.Column="1" Command="{Binding ToggleSignalsPaneCommand}" Background="Transparent" BorderThickness="0" Padding="4" ToolTip.Tip="Collapse">
                                    <mi:MaterialIcon Kind="ChevronLeft" Width="14" Height="14" Foreground="{DynamicResource SystemAccentColor}"/>
                                </Button>
                            </Grid>
                        </Border>
                        <views:SignalsView Grid.Row="1" />
                    </Grid>
                </Border>

                <!-- GridSplitter -->
                <GridSplitter Grid.Column="1" Width="4" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" IsVisible="{Binding IsSignalsPaneOpen}"/>

                <!-- Plot Area -->
                <Border Grid.Column="2" Padding="15">
                    <Grid RowDefinitions="*, Auto">
                        <Grid Grid.Row="0" RowDefinitions="Auto, *">
                            <!-- Tab Strip with Add Button -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TabStrip ItemsSource="{Binding Plots}" SelectedItem="{Binding SelectedPlot}" BorderThickness="0">
                                    <TabStrip.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </TabStrip.ItemsPanel>
                                    <TabStrip.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="12"/>
                                                <Button Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemovePlotCommand}" 
                                                        CommandParameter="{Binding}"
                                                        Padding="2" Background="Transparent" BorderThickness="0"
                                                        ToolTip.Tip="Close Plot">
                                                    <mi:MaterialIcon Kind="Close" Width="14" Height="14" Foreground="#d83b01"/>
                                                </Button>
                                            </StackPanel>
                                        </DataTemplate>
                                    </TabStrip.ItemTemplate>
                                </TabStrip>
                                
                                <Button Command="{Binding AddEmptyPlotCommand}" 
                                        ToolTip.Tip="New Plot"
                                        Background="Transparent" BorderThickness="0" Padding="8,4"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding CanAddPlot}">
                                    <mi:MaterialIcon Kind="Plus" Width="18" Height="18" Foreground="{DynamicResource SystemAccentColor}"/>
                                </Button>
                            </StackPanel>

                            <!-- Plot Content -->
                            <ContentControl Grid.Row="1" Content="{Binding SelectedPlot}">
                                <ContentControl.ContentTemplate>
                                    <DataTemplate x:DataType="vm:PlotViewModel">
                                        <views:PlotView />
                                    </DataTemplate>
                                </ContentControl.ContentTemplate>
                            </ContentControl>
                        </Grid>
                        
                        <!-- Replay Controls - Bottom of Plot -->
                        <Border Grid.Row="1" 
                                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
                                CornerRadius="4" 
                                Padding="8,3" 
                                Margin="0,5,0,0"
                                IsVisible="{Binding IsPlaybackBarVisible}">
                            <Grid ColumnDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, *, Auto">
                                <!-- Fast Backward (1%) -->
                                <Button Grid.Column="0" Command="{Binding FastBackwardCommand}" ToolTip.Tip="Fast Backward (1%)" Background="Transparent" BorderThickness="0" Width="32" Height="32" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="SkipBackward" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Step Back -->
                                <Button Grid.Column="1" Command="{Binding StepBackwardCommand}" ToolTip.Tip="Step Back" Background="Transparent" BorderThickness="0" Width="32" Height="32" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="ChevronLeft" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Play/Pause -->
                                <Button Grid.Column="2" Command="{Binding PlayPauseCommand}" ToolTip.Tip="Play/Pause" Background="Transparent" BorderThickness="0" Width="32" Height="32" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="{Binding IsPlaying, Converter={x:Static converters:BoolToPlayIconConverter.Instance}}" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Step Forward -->
                                <Button Grid.Column="3" Command="{Binding StepForwardCommand}" ToolTip.Tip="Step Forward" Background="Transparent" BorderThickness="0" Width="32" Height="32" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="ChevronRight" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Fast Forward (1%) -->
                                <Button Grid.Column="4" Command="{Binding FastForwardCommand}" ToolTip.Tip="Fast Forward (1%)" Background="Transparent" BorderThickness="0" Width="32" Height="32" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="SkipForward" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>

                                <!-- Timestamp Display -->
                                <Border Grid.Column="5" 
                                        Background="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                                        CornerRadius="2"
                                        Padding="8,2"
                                        Margin="10,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FormattedPlaybackTime}" 
                                               FontFamily="Consolas, Courier New, monospace" 
                                               FontSize="11.5" 
                                               LineHeight="14"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource SystemAccentColor}"
                                               FontWeight="SemiBold"/>
                                </Border>

                                <!-- Restart -->
                                <Button Grid.Column="6" Command="{Binding RestartCommand}" ToolTip.Tip="Restart" Background="Transparent" BorderThickness="0" Width="32" Height="32" Margin="0,0,15,0" IsEnabled="{Binding !IsStreaming}">
                                    <mi:MaterialIcon Kind="Replay" Width="18" Height="18" Foreground="#107c10"/>
                                </Button>
                                
                                <!-- Timeline Slider -->
                                <Slider Grid.Column="7" Value="{Binding PlaybackProgress}" Minimum="0" Maximum="100" VerticalAlignment="Center" IsEnabled="{Binding !IsStreaming}"/>
                                
                                <!-- Speed -->
                                <ComboBox Grid.Column="8" ItemsSource="{Binding PlaybackSpeeds}" SelectedItem="{Binding PlaybackSpeed, Converter={x:Static converters:DoubleToStringConverter.Instance}}" Width="90" Margin="10,0,0,0" VerticalAlignment="Center" IsEnabled="{Binding !IsStreaming}"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
