<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SignalBench.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mi="using:Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="520"
        x:Class="SignalBench.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        WindowStartupLocation="CenterOwner"
        Width="550" Height="520"
        CanResize="False">

    <Grid RowDefinitions="*, Auto">
        <ScrollViewer Grid.Row="0">
            <Border Padding="20">
                <StackPanel Spacing="25">
                    <!-- General Tab Content -->
                    <StackPanel Spacing="15">
                        <TextBlock Text="PATHS" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Default Telemetry Folder:" FontSize="13"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Text="{Binding DefaultTelemetryPath}" Watermark="Not set..."/>
                                <Button Grid.Column="1" Command="{Binding BrowsePathCommand}" CommandParameter="Telemetry" Margin="5,0,0,0">
                                    <mi:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Default Schema Folder:" FontSize="13"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Text="{Binding DefaultSchemaPath}" Watermark="Not set..."/>
                                <Button Grid.Column="1" Command="{Binding BrowsePathCommand}" CommandParameter="Schema" Margin="5,0,0,0">
                                    <mi:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <Separator Height="1" Margin="0,5"/>

                    <!-- Application Section -->
                    <StackPanel Spacing="15">
                        <TextBlock Text="APPLICATION" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                        
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto">
                            <StackPanel Grid.Row="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock Text="Theme:" FontSize="13"/>
                                <TextBlock Text="Restart may be required for full effect" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Row="0" Grid.Column="1" Width="150" 
                                      ItemsSource="{Binding Themes}" 
                                      SelectedItem="{Binding Theme}"/>

                            <StackPanel Grid.Row="1" Spacing="2" Margin="0,20,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Data Storage:" FontSize="13"/>
                                <TextBlock Text="Use SQLite for very large files" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <ComboBox Grid.Row="1" Grid.Column="1" Width="150" Margin="0,20,0,0"
                                      ItemsSource="{Binding StorageModes}" 
                                      SelectedItem="{Binding StorageMode}"/>

                            <StackPanel Grid.Row="2" Spacing="2" Margin="0,20,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Auto-load Last Session:" FontSize="13"/>
                                <TextBlock Text="Open last used session on startup" FontSize="11" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Row="2" Grid.Column="1" IsChecked="{Binding AutoLoadLastSession}" Margin="0,20,0,0" OnContent="" OffContent=""/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="1" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="20,15" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12">
                <Button Content="Cancel" Command="{Binding CancelCommand}" Width="100" HorizontalContentAlignment="Center"/>
                <Button Content="Save" Command="{Binding SaveCommand}" Width="100" HorizontalContentAlignment="Center" Classes="accent"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
