<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SignalBench.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:views="using:SignalBench.Views"
             x:Class="SignalBench.Views.SignalsView"
             x:DataType="vm:PlotViewModel">
    <Grid RowDefinitions="*, Auto">
        <ScrollViewer Grid.Row="0">
            <StackPanel Margin="10,5,5,5">
                <!-- Regular Signals -->
                <ListBox ItemsSource="{Binding RegularSignals}"
                         Background="Transparent"
                         BorderThickness="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0,2"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SignalItemViewModel">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           FontSize="13"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding CurrentValue, StringFormat={}{0:G5}}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Margin="10,0,0,0"
                                           IsVisible="{Binding IsSelected}"
                                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Derived Signals Section -->
                <StackPanel IsVisible="{Binding DerivedSignals.Count}">
                    <TextBlock Text="DERIVED SIGNALS" Classes="SectionHeader"/>
                    <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding AvailableSignals}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:SignalItemViewModel">
                                <Grid ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,2" IsVisible="{Binding IsDerived}">
                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                              Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Foreground="#107c10"/>
                                    <TextBlock Grid.Column="2" Text="{Binding CurrentValue, StringFormat={}{0:G5}}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="10,0,0,0"
                                               IsVisible="{Binding IsSelected}"
                                               Foreground="#107c10"/>
                                    <Button Grid.Column="3" 
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditDerivedSignalCommand}"
                                            CommandParameter="{Binding Name}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="4,2"
                                            Margin="4,0,0,0"
                                            ToolTip.Tip="Edit">
                                        <mi:MaterialIcon Kind="Pencil" Width="14" Height="14" Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Statistics Section -->
        <Expander Grid.Row="1" 
                  IsExpanded="True"
                  HorizontalAlignment="Stretch"
                  Padding="0"
                  MinHeight="32"
                  BorderThickness="0,1,0,0">
            <Expander.Styles>
                <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
                    <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"/>
                    <Setter Property="Height" Value="32"/>
                    <Setter Property="MinHeight" Value="32"/>
                    <Setter Property="Padding" Value="10,0"/>
                </Style>
            </Expander.Styles>
            <Expander.Header>
                <TextBlock Text="STATISTICS" Classes="PanelHeader"/>
            </Expander.Header>
            <views:SignalStatsView DataContext="{Binding Statistics}" />
        </Expander>
    </Grid>
</UserControl>
