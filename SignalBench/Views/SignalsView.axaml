<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SignalBench.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             xmlns:converters="using:SignalBench.ViewModels"
             x:Class="SignalBench.Views.SignalsView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer>
        <StackPanel Margin="10,5,5,5">
            <!-- Regular Signals -->
            <ListBox ItemsSource="{Binding RegularSignals}"
                     Background="Transparent"
                     BorderThickness="0">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0,2"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SignalItemViewModel">
                        <Grid ColumnDefinitions="Auto, *">
                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                      Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                       FontSize="13"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Derived Signals Section -->
            <StackPanel IsVisible="{Binding DerivedSignals.Count}">
                <TextBlock Text="DERIVED SIGNALS" 
                           FontSize="11" 
                           FontWeight="Bold" 
                           Foreground="#605e5c" 
                           Margin="0,15,0,5"/>
                <Border Height="1" Background="#e1dfdd" Margin="0,0,0,5"/>
                <ItemsControl ItemsSource="{Binding AvailableSignals}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:SignalItemViewModel">
                            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,2" IsVisible="{Binding IsDerived}">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                          Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Foreground="#107c10"/>
                                <Button Grid.Column="2" 
                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).EditDerivedSignalCommand}"
                                        CommandParameter="{Binding Name}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,2"
                                        Margin="4,0,0,0"
                                        ToolTip.Tip="Edit">
                                    <mi:MaterialIcon Kind="Pencil" Width="14" Height="14" Foreground="#605e5c"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
